{
  "name": "zomitron",
  "version": "1.0.0",
  "description": "Zomitron - Multivendor Quick-Commerce Platform",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd zom-main-back && npm run dev",
    "client": "cd zom-main-front && npm run dev",
    "install:all": "npm install && cd zom-main-back && npm install && cd ../zom-main-front && npm install",
    "seed": "cd zom-main-back && npm run seed",
    "test": "cd zom-main-back && npm test"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
